<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.newsradar</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/uv</string>
        <string>run</string>
        <string>newsradar</string>
        <string>--config</string>
        <string>/path/to/news-radar/config.toml</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/path/to/news-radar</string>

    <!-- Run daily at 8:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Wake the machine if asleep -->
    <key>WakeForJob</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/path/to/news-radar/logs/newsradar-agent.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/news-radar/logs/newsradar-agent.log</string>
</dict>
</plist>
